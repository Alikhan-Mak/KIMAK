# Copy this file to .env and fill in your keys

# Anthropic API key — required for AI analysis and complaint classification
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token for dispatcher alerts (optional)
# Create a bot via @BotFather on Telegram
TELEGRAM_NOTIFY_TOKEN=

# Telegram bot token for citizen complaint intake (optional)
TELEGRAM_BOT_TOKEN=

# Telegram channel or group ID for dispatcher alerts (optional)
# e.g. -1001234567890
DISPATCHER_CHAT_ID=
